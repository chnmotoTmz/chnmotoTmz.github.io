{
  "workflow_name": "ArticleGenerationPipeline_V2",
  "description": "V2 workflow with improved command parsing and style prompt handling.",
  "trigger": {
    "type": "webhook",
    "source": "line",
    "url_prefix": "/api/webhook",
    "endpoint": "/line",
    "method": "POST",
    "description": "Triggered by LINE webhook events for user messages"
  },
  "steps": [
    {
      "id": "fetch_data",
      "module": "DatabaseFetcher",
      "description": "Fetches all necessary data from the database.",
      "inputs": {
        "user_id": "${initial_input.user_id}",
        "message_ids": "${initial_input.message_ids}"
      },
      "outputs": {
        "user": "user_data",
        "blog": "blog_data",
        "messages": "messages_data",
        "assets": "assets_data",
        "message_ids": "original_message_ids"
      },
      "on_success": "prepare_prompt",
      "on_failure": "handle_error"
    },
    {
      "id": "prepare_prompt",
      "module": "PromptPreparer",
      "description": "Prepares texts, image URLs, and link lists for the AI prompt.",
      "inputs": {
        "messages": "${messages_data}",
        "assets": "${assets_data}"
      },
      "outputs": {
        "texts": "prompt_texts",
        "images_for_prompt": "prompt_images",
        "youtube_links": "youtube_links",
        "web_links": "web_links"
      },
      "on_success": "parse_commands",
      "on_failure": "handle_error"
    },
    {
      "id": "parse_commands",
      "module": "CommandParserTask",
      "description": "[V2] Parses commands from all input messages. Extracts !, @, # commands and style prompts.",
      "inputs": {
        "texts": "${prompt_texts}",
        "user_id": "${initial_input.user_id}",
        "line_user_id": "${initial_input.line_user_id}",
        "channel_id": "${initial_input.channel_id}"
      },
      "outputs": {
        "command_context": "command_context",
        "cleaned_texts": "cleaned_texts",
        "style_prompt": "style_prompt",
        "stop_workflow": "stop_workflow",
        "message": "parser_message"
      },
      "on_success": "resolve_blog_context",
      "on_failure": "handle_error"
    },
    {
      "id": "resolve_blog_context",
      "module": "BlogContextResolverTask",
      "description": "Ensures blog context is set from command or default.",
      "inputs": {
        "command_context": "${command_context}",
        "default_blog": "政治"
      },
      "outputs": {
        "blog": "blog_data"
      },
      "on_success": "web_summary_fetcher",
      "on_failure": "handle_error"
    },
    {
      "id": "web_summary_fetcher",
      "module": "WebSummaryFetcher",
      "description": "Fetches web page summaries from shared links.",
      "inputs": {
        "web_links": {
          "var": "${web_links}",
          "optional": true
        }
      },
      "outputs": {
        "web_summaries": "web_summaries"
      },
      "on_success": "video_summary_fetcher",
      "on_failure": "video_summary_fetcher"
    },
    {
      "id": "video_summary_fetcher",
      "module": "VideoSummaryFetcher",
      "description": "Fetches YouTube video information.",
      "inputs": {
        "youtube_links": "${youtube_links}"
      },
      "outputs": {
        "video_summaries": "video_summaries"
      },
      "on_success": "select_blog",
      "on_failure": "select_blog"
    },
    {
      "id": "select_blog",
      "module": "BlogSelectorTaskV2",
      "description": "[V2] Selects blog based on command context. Handles repost mode and style prompts.",
      "inputs": {
        "command_context": "${command_context}",
        "cleaned_texts": "${cleaned_texts}",
        "style_prompt": "${style_prompt}",
        "images_for_prompt": "${prompt_images}"
      },
      "outputs": {
        "blog_config": "selected_blog_data",
        "cleaned_texts": "processed_texts",
        "style_prompt": "style_prompt",
        "repost_data": "repost_data"
      },
      "on_success": "update_blog_context",
      "on_failure": "handle_error"
    },
    {
      "id": "update_blog_context",
      "module": "BlogContextUpdaterTask",
      "description": "Updates blog context if a new valid selection is made.",
      "inputs": {
        "current_blog": "${blog_data}",
        "new_blog": "${selected_blog_data}"
      },
      "outputs": {
        "blog": "blog_data"
      },
      "on_success": "check_repost_mode",
      "on_failure": "handle_error"
    },
    {
      "id": "check_repost_mode",
      "module": "RepostModeCheckerTask",
      "description": "Checks if this is a repost request and determines the repost mode.",
      "inputs": {
        "command_context": "${command_context}",
        "style_prompt": "${style_prompt}",
        "cleaned_texts": "${processed_texts}"
      },
      "outputs": {
        "is_repost": "is_repost",
        "structured_post_id": "structured_post_id",
        "repost_mode": "repost_mode",
        "repost_data": "repost_data",
        "cleaned_texts": "processed_texts"
      },
      "on_success": "branch_repost_or_new",
      "on_failure": "handle_error"
    },
    {
      "id": "branch_repost_or_new",
      "module": "ConditionalBranchTask",
      "description": "Branches workflow based on whether this is a repost or new article.",
      "inputs": {
        "condition": "${is_repost}"
      },
      "outputs": {},
      "on_true": "load_structured_data",
      "on_false": "define_concept",
      "on_failure": "handle_error"
    },
    {
      "id": "load_structured_data",
      "module": "StructuredDataLoaderTask",
      "description": "Loads structured data for repost regeneration.",
      "inputs": {
        "structured_post_id": "${structured_post_id}"
      },
      "outputs": {
        "structured_data": "structured_data"
      },
      "on_success": "prepare_repost_context",
      "on_failure": "handle_error"
    },
    {
      "id": "prepare_repost_context",
      "module": "RepostContextPreparerTask",
      "description": "Prepares context for repost article generation.",
      "inputs": {
        "structured_data": "${structured_data}",
        "style_prompt": "${style_prompt}",
        "repost_mode": "${repost_mode}"
      },
      "outputs": {
        "article_concept": "article_concept",
        "article_structure": "article_structure",
        "repost_context": "repost_context"
      },
      "on_success": "generate_from_structured",
      "on_failure": "handle_error"
    },
    {
      "id": "generate_from_structured",
      "module": "StructuredArticleGeneratorTask",
      "description": "Generates article content from structured data.",
      "inputs": {
        "structured_data": "${structured_data}",
        "style_prompt": "${style_prompt}",
        "repost_context": "${repost_context}",
        "blog": "${blog_data}"
      },
      "outputs": {
        "title": "base_title",
        "content": "base_content"
      },
      "on_success": "remove_amazon_links",
      "on_failure": "handle_error"
    },
    {
      "id": "define_concept",
      "module": "ArticleConceptDefiner",
      "description": "Defines the article's concept.",
      "inputs": {
        "texts": "${processed_texts}",
        "images_for_prompt": "${prompt_images}",
        "blog": "${blog_data}",
        "web_summaries": "${web_summaries}",
        "repost_data": "${repost_data}",
        "new_chat": "${new_chat}"
      },

      "outputs": {
        "article_concept": "article_concept",
        "content_analysis": "content_analysis"
      },
      "on_success": "plan_strategy",
      "on_failure": "handle_error"
    },
    {
      "id": "plan_strategy",
      "module": "ArticleStrategyPlanner",
      "description": "Plans article structure, affiliate strategy, and thumbnail concept.",
      "inputs": {
        "article_concept": "${article_concept}",
        "content_analysis": "${content_analysis}",
        "texts": "${processed_texts}",
        "web_summaries": "${web_summaries}",
        "video_summaries": "${video_summaries}",
        "blog": "${blog_data}"
      },
      "outputs": {
        "article_structure": "article_structure",
        "affiliate_strategy": "affiliate_strategy",
        "thumbnail_concept": "thumbnail_concept",
        "target_keywords": "target_keywords",
        "mentioned_products": "mentioned_products"
      },
      "on_success": "fetch_similar_articles",
      "on_failure": "fetch_similar_articles"
    },
    {
      "id": "fetch_similar_articles",
      "module": "RagSimilarArticlesFetcher",
      "description": "Retrieves similar articles from RAG for context enrichment.",
      "config": {
        "enabled": true
      },
      "inputs": {
        "texts": "${processed_texts}",
        "article_concept": "${article_concept}",
        "blog": "${blog_data}",
        "web_summaries": "${web_summaries}"
      },
      "outputs": {
        "similar_articles": "similar_articles",
        "writing_style_hints": "writing_style_hints"
      },
      "on_success": "generate_content",
      "on_failure": "generate_content"
    },
    {
      "id": "generate_content",
      "module": "ArticleContentGenerator",
      "description": "Generates article title, content, and thumbnail prompt with style instructions.",
      "inputs": {
        "texts": "${processed_texts}",
        "images_for_prompt": "${prompt_images}",
        "blog": "${blog_data}",
        "article_concept": "${article_concept}",
        "content_analysis": "${content_analysis}",
        "similar_articles": "${similar_articles}",
        "writing_style_hints": "${writing_style_hints}",
        "video_summaries": "${video_summaries}",
        "web_summaries": "${web_summaries}",
        "repost_data": "${repost_data}",
        "article_structure": "${article_structure}",
        "affiliate_strategy": "${affiliate_strategy}",
        "style_prompt": "${style_prompt}",
        "thumbnail_concept": "${thumbnail_concept}",
        "new_chat": "${new_chat}"
      },

      "outputs": {
        "title": "base_title",
        "content": "base_content",
        "thumbnail_prompt": "generated_thumbnail_prompt",
        "generation_mode": "generation_mode"
      },
      "on_success": "add_affiliate_links",
      "on_failure": "handle_error"
    },
    {
      "id": "add_affiliate_links",
      "module": "AffiliateLinkAdderTask",
      "description": "Adds affiliate links to product mentions in the content.",
      "inputs": {
        "content": "${base_content}",
        "affiliate_strategy": "${affiliate_strategy}",
        "article_concept": "${article_concept}"
      },
      "outputs": {
        "content_with_affiliates": "base_content"
      },
      "on_success": "cache_article",
      "on_failure": "cache_article"
    },
    {
      "id": "cache_article",
      "module": "ArticleCacheTask",
      "description": "Caches the generated article data for potential reposting.",
      "inputs": {
        "title": "${base_title}",
        "content": "${base_content}",
        "article_concept": "${article_concept}",
        "article_structure": "${article_structure}",
        "affiliate_strategy": "${affiliate_strategy}",
        "blog": "${blog_data}",
        "repost_mode": "${repost_mode}",
        "repost_data": "${repost_data}"
      },
      "outputs": {},
      "on_success": "remove_amazon_links",
      "on_failure": "remove_amazon_links"
    },
    {
      "id": "remove_amazon_links",
      "module": "AmazonLinkRemoverTask",
      "description": "Removes Amazon links and replaces with Rakuten alternatives.",
      "config": {
        "enabled": true
      },
      "inputs": {
        "title": "${base_title}",
        "content": "${base_content}"
      },
      "outputs": {
        "title": "base_title",
        "content": "base_content"
      },
      "on_success": "add_linked_sources",
      "on_failure": "add_linked_sources"
    },
    {
      "id": "add_linked_sources",
      "module": "AddLinkedSourcesTask",
      "description": "Appends reference section with source links.",
      "inputs": {
        "content": "${base_content}",
        "web_summaries": "${web_summaries}",
        "section_title": "📚 出典リンク"
      },
      "outputs": {
        "content_with_links": "content_with_links"
      },
      "on_success": "add_thumbnail",
      "on_failure": "add_thumbnail"
    },
    {
      "id": "add_thumbnail",
      "module": "ThumbnailGenerator",
      "description": "Adds thumbnail image to content.",
      "config": {
        "enabled": true
      },
      "inputs": {
        "title": "${base_title}",
        "content": "${content_with_links}",
        "thumbnail_prompt": "${generated_thumbnail_prompt}",
        "new_chat": "${new_chat}"
      },

      "outputs": {
        "enhanced_content": "content_with_thumbnail"
      },
      "on_success": "add_fact_check",
      "on_failure": "add_fact_check"
    },
    {
      "id": "add_fact_check",
      "module": "FactChecker",
      "description": "Adds fact-check references.",
      "config": {
        "enabled": true
      },
      "inputs": {
        "title": "${base_title}",
        "content": "${content_with_thumbnail}",
        "web_summaries": "${web_summaries}"
      },
      "outputs": {
        "enhanced_content": "content_with_facts"
      },
      "on_success": "review_article",
      "on_failure": "review_article"
    },
    {
      "id": "review_article",
      "module": "ArticleReviewer",
      "description": "Reviews article quality and provides feedback.",
      "config": {
        "enabled": true
      },
      "inputs": {
        "title": "${base_title}",
        "content": "${content_with_facts}",
        "article_concept": "${article_concept}",
        "similar_articles": "${similar_articles}",
        "blog": "${blog_data}",
        "web_summaries": "${web_summaries}",
        "video_summaries": "${video_summaries}",
        "style_prompt": "${style_prompt}",
        "images": "${prompt_images}"
      },
      "outputs": {
        "review_feedback": "review_feedback",
        "has_issues": "has_review_issues",
        "revised_content": "final_content"
      },
      "on_success": "branch_review_result",
      "on_failure": "branch_review_result"
    },
    {
      "id": "branch_review_result",
      "module": "ConditionalBranchTask",
      "description": "Branches based on review result - revise if issues found, proceed if OK.",
      "inputs": {
        "condition": "${has_review_issues}"
      },
      "outputs": {},
      "on_true": "revise_article",
      "on_false": "set_final_content_no_revision",
      "on_failure": "handle_error"
    },
    {
      "id": "revise_article",
      "module": "ArticleReviser",
      "description": "Revises article based on review feedback.",
      "inputs": {
        "title": "${base_title}",
        "content": "${content_with_facts}",
        "review_feedback": "${review_feedback}",
        "article_concept": "${article_concept}",
        "blog": "${blog_data}",
        "similar_articles": "${similar_articles}",
        "web_summaries": "${web_summaries}",
        "video_summaries": "${video_summaries}",
        "images": "${prompt_images}"
      },
      "outputs": {
        "revised_title": "final_title",
        "revised_content": "final_content",
        "validation_issues": "validation_issues",
        "sanitization_notes": "sanitization_notes"
      },
      "on_success": "add_affiliate_links_final",
      "on_failure": "handle_error"
    },
    {
      "id": "set_final_content_no_revision",
      "module": "PassthroughTask",
      "description": "Sets final content when no revision needed.",
      "inputs": {
        "title": "${base_title}",
        "content": "${final_content}"
      },
      "outputs": {
        "title": "final_title",
        "content": "final_content"
      },
      "on_success": "add_affiliate_links_final",
      "on_failure": "add_affiliate_links_final"
    },
    {
      "id": "add_affiliate_links_final",
      "module": "AffiliateLinkAdderTask",
      "description": "Adds affiliate links to product mentions in the final content before posting.",
      "inputs": {
        "content": "${final_content}",
        "affiliate_strategy": "${affiliate_strategy}",
        "article_concept": "${article_concept}"
      },
      "outputs": {
        "content_with_affiliates": "final_content"
      },
      "on_success": "save_draft",
      "on_failure": "save_draft"
    },
    {
      "id": "save_draft",
      "module": "DraftPersister",
      "description": "Saves the reviewed article as a draft in the database.",
      "inputs": {
        "blog": "${blog_data}",
        "user": "${user_data}",
        "title": "${final_title}",
        "content": "${final_content}",
        "message_ids": "${original_message_ids}"
      },
      "outputs": {
        "post_id": "draft_post_id"
      },
      "on_success": "post_to_hatena",
      "on_failure": "handle_error"
    },
    {
      "id": "post_to_hatena",
      "module": "HatenaPublisher",
      "description": "Posts article to Hatena Blog.",
      "inputs": {
        "blog": "${blog_data}",
        "post_id": "${draft_post_id}",
        "article_concept": "${article_concept}"
      },
      "outputs": {
        "hatena_entry": "hatena_entry"
      },
      "on_success": "notify_user",
      "on_failure": "handle_error"
    },
    {
      "id": "notify_user",
      "module": "LineNotifier",
      "description": "Sends success notification to LINE user.",
      "inputs": {
        "line_user_id": "${initial_input.line_user_id}",
        "channel_id": "${initial_input.channel_id}",
        "final_post_title": "${base_title}",
        "hatena_entry": "${hatena_entry}",
        "blog": "${blog_data}"
      },
      "outputs": {},
      "terminal": true
    },
    {
      "id": "handle_error",
      "module": "LineNotifier",
      "description": "Handles workflow errors and notifies user.",
      "inputs": {
        "line_user_id": "${initial_input.line_user_id}",
        "channel_id": "${initial_input.channel_id}",
        "last_error_message": "${last_error_message}",
        "message_type": "failure"
      },
      "outputs": {},
      "terminal": true
    }
  ],
  "variables": {
    "user_data": null,
    "blog_data": null,
    "messages_data": null,
    "assets_data": null,
    "prompt_texts": [],
    "prompt_images": [],
    "youtube_links": [],
    "web_links": [],
    "web_summaries": [],
    "video_summaries": [],
    "command_context": {},
    "cleaned_texts": [],
    "processed_texts": [],
    "style_prompt": null,
    "stop_workflow": false,
    "repost_data": null,
    "is_repost": false,
    "structured_post_id": null,
    "repost_mode": null,
    "structured_data": null,
    "repost_context": null,
    "article_concept": "",
    "article_structure": null,
    "affiliate_strategy": null,
    "thumbnail_concept": null,
    "target_keywords": [],
    "similar_articles": [],
    "writing_style_hints": "",
    "base_title": "",
    "base_content": "",
    "generated_thumbnail_prompt": "",
    "content_with_links": "",
    "content_with_thumbnail": "",
    "content_with_facts": "",
    "reviewed_content": "",
    "final_content": "",
    "final_title": "",
    "draft_post_id": null,
    "hatena_entry": null,
    "published_url": "",
    "post_success": false,
    "content_analysis": null,
    "generation_mode": "standard",
    "input_completeness": null,
    "mentioned_products": [],
    "validation_issues": [],
    "new_chat": true,
    "selected_blog_data": null
  }
}
