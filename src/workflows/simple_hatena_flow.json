{
  "workflow_name": "SimpleHatenaPipeline",
  "description": "A minimal workflow to generate a text post with a thumbnail and publish to Hatena.",
  "trigger": {
    "type": "manual",
    "description": "Triggered manually via CLI"
  },
  "steps": [
    {
      "id": "generate_content",
      "module": "ArticleContentGenerator",
      "description": "Generates the main article title, content, and thumbnail prompt.",
      "inputs": {
        "texts": "${initial_input.texts}",
        "images_for_prompt": [],
        "blog": "${initial_input.blog}",
        "article_concept": "${initial_input.article_concept}",
        "web_summaries": [],
        "similar_articles": [],
        "writing_style_hints": "",
        "video_summaries": [],
        "repost_data": null,
        "article_structure": [],
        "affiliate_strategy": {},
        "style_prompt": "シンプルに、短めの記事を書いてください。"
      },
      "outputs": {
        "title": "base_title",
        "content": "base_content",
        "thumbnail_prompt": "generated_thumbnail_prompt"
      },
      "on_success": "add_thumbnail",
      "on_failure": "end"
    },
    {
      "id": "add_thumbnail",
      "module": "ThumbnailGenerator",
      "description": "Adds a thumbnail image to the content using the pre-generated prompt.",
      "config": { "enabled": true },
      "inputs": {
        "title": "${base_title}",
        "content": "${base_content}",
        "thumbnail_prompt": "${generated_thumbnail_prompt}"
      },
      "outputs": {
        "enhanced_content": "content_with_thumbnail"
      },
      "on_success": "persist_draft",
      "on_failure": "persist_draft"
    },
    {
      "id": "persist_draft",
      "module": "DraftPersister",
      "description": "Saves the final article as a draft in the database.",
      "inputs": {
        "blog": "${initial_input.blog}",
        "user": "${initial_input.user}",
        "title": "${base_title}",
        "content": "${content_with_thumbnail}",
        "message_ids": "${initial_input.message_ids}"
      },
      "outputs": {
        "post_id": "draft_post_id"
      },
      "on_success": "publish_to_hatena",
      "on_failure": "end"
    },
    {
      "id": "publish_to_hatena",
      "module": "HatenaPublisher",
      "description": "Publishes the article to Hatena Blog.",
      "inputs": {
        "blog": "${initial_input.blog}",
        "post_id": "${draft_post_id}",
        "title": "${base_title}",
        "content": "${content_with_thumbnail}",
        "article_concept": "${initial_input.article_concept}"
      },
      "outputs": {
        "hatena_entry": "hatena_entry_details"
      },
      "on_success": "end",
      "on_failure": "end"
    }
  ]
}
